{
  "version": 2,
  "builds": [
    {
      "src": "src/ynab_mcp_server/http_server.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "15mb",
        "runtime": "python3.11"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "src/ynab_mcp_server/http_server.py"
    }
  ]
}
